NODE_ENV=development
PORT=7000

# Database
DATABASE_URL=postgresql://chess_user:chess_pass@localhost:5432/chess_insight

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Engine
STOCKFISH_PATH=/usr/games/stockfish
ENGINE_DEPTH=18
ENGINE_MAX_CONCURRENT=2

# File Upload
MAX_FILE_SIZE_MB=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ANALYSIS_RATE_LIMIT_MAX=10

# Optional: OpenAI for move explanations
OPENAI_API_KEY=
