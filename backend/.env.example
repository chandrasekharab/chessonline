NODE_ENV=development
PORT=7000

# Database
DATABASE_URL=postgresql://chess_user:chess_pass@localhost:5432/chess_insight

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Engine
STOCKFISH_PATH=/usr/games/stockfish
ENGINE_DEPTH=18
ENGINE_MAX_CONCURRENT=2

# File Upload
MAX_FILE_SIZE_MB=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ANALYSIS_RATE_LIMIT_MAX=10

# Optional: OpenAI for move explanations (leave empty when using local LLM)
OPENAI_API_KEY=

# ─── AI Explanation Engine ─────────────────────────────────────────────────────
# Set AI_EXPLANATIONS_ENABLED=true and configure ONE provider section below.
AI_EXPLANATIONS_ENABLED=false

# ── Option A: LM Studio (local, free, recommended for dev) ───────────────────
# 1. Open LM Studio → Local Server tab → click "Start Server"
# 2. Load any chat model (mistral, llama3, gemma2, phi3, qwen2.5, etc.)
# 3. Uncomment and set:
#
# LLM_PROVIDER=custom
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model          # use whatever model ID LM Studio shows
# OPENAI_API_KEY=lm-studio       # any non-empty string — LM Studio ignores it
#
# Running inside Docker? Replace localhost with the host machine:
# LLM_BASE_URL=http://host.docker.internal:1234/v1

# ── Option B: OpenAI ─────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── Option C: Anthropic ──────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-haiku-20240307
# ANTHROPIC_API_KEY=sk-ant-...

# ── Option D: Ollama ─────────────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# ── Active provider settings (fill from your chosen option above) ─────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
ANTHROPIC_API_KEY=

# LLM generation settings
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.4

# Only generate explanations for moves with eval drop >= this (centipawns)
EXPLANATION_MIN_DROP_CP=100

# Redis TTL for cached explanations in seconds (default: 30 days)
EXPLANATION_CACHE_TTL_S=2592000
